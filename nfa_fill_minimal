import time

from playwright.sync_api import sync_playwright

LOGIN_URL = "https://www4.sefaz.pb.gov.br/atf/seg/SEGf_Login.jsp"
FORM_URL = "https://www4.sefaz.pb.gov.br/atf/fis/FISf_EmitirNFAeReparticao.do?limparSessao=true"

USERNAME = "eduardof"
PASSWORD = "atf101010"


def fill_fast(frame, sel, value):
    frame.fill(sel, value)
    time.sleep(0.3)


def main():
    with sync_playwright() as p:
        browser = p.chromium.launch(
            headless=False, args=["--disable-blink-features=AutomationControlled"]
        )
        context = browser.new_context()
        page = context.new_page()

        print("🌐 Opening login...")
        page.goto(LOGIN_URL, wait_until="domcontentloaded")

        print("🔐 Filling username/password...")
        page.fill("input[name='edtNoLogin']", USERNAME)
        page.fill("input[name='edtDsSenha']", PASSWORD)

        print("➡️ Submitting...")
        page.click("button[name='btnAvancar']")
        time.sleep(3)

        print("➡️ Going directly to FORM...")
        page.goto(FORM_URL, wait_until="domcontentloaded")
        time.sleep(5)  # Wait longer for form to load

        # ===== FORM IS NOW ON MAIN PAGE (not in iframe) =====
        # Wait for form to be ready on main page
        print("⏳ Waiting for form to load on main page...")
        try:
            page.wait_for_selector("select[name='cmbNaturezaOperacao']", timeout=15000)
            print("✅ Form found on main page.")
        except Exception as e:
            print(f"⚠️  Form selector not found, trying alternative detection...")
            # Try alternative selectors
            try:
                page.wait_for_selector("table:has-text('Emitente')", timeout=10000)
                print("✅ Form found via alternative selector.")
            except Exception:
                print("❌ Form not found on main page.")
                return

        # Use page directly (form is on main page, not in iframe)
        form_frame = page

        # ================================
        # START FILLING REAL FORM FIELDS
        # ================================

        print("🧾 Filling Natureza Operação...")
        form_frame.wait_for_selector(
            "select[name='cmbNaturezaOperacao']", timeout=10000
        )
        form_frame.select_option("select[name='cmbNaturezaOperacao']", "75")
        time.sleep(0.5)

        print("📌 Filling Motivo...")
        form_frame.wait_for_selector("select[name='cmbMotivo']", timeout=10000)
        form_frame.select_option("select[name='cmbMotivo']", "1")
        time.sleep(0.5)

        print("🔄 Filling Tipo Operação...")
        form_frame.wait_for_selector("select[name='cmbTpOperacao']", timeout=10000)
        form_frame.select_option("select[name='cmbTpOperacao']", "S")
        time.sleep(0.5)

        print("📦 Filling CFOP...")
        # Try multiple selectors for CFOP field
        cfop_filled = False
        cfop_selectors = [
            "input[name='cmbNrCfop']",
            "input[name='edtNrCfop']",
            "input[id*='Cfop' i]",
            "input[id*='CFOP' i]",
        ]
        for selector in cfop_selectors:
            try:
                form_frame.wait_for_selector(selector, timeout=5000)
                form_frame.fill(selector, "6908")
                print(f"  ✓ CFOP filled using selector: {selector}")
                cfop_filled = True
                break
            except Exception:
                continue
        if not cfop_filled:
            print("  ⚠️  CFOP field not found, continuing...")
        time.sleep(0.5)

        # ===== PRODUCT AREA =====
        print("📦 Filling product description...")
        form_frame.wait_for_selector(
            "textarea[name='txaDsDetalheProduto']", timeout=10000
        )
        form_frame.fill("textarea[name='txaDsDetalheProduto']", "SERVIÇO DE REMESSA")
        time.sleep(0.5)

        print("📏 Filling Unidade Medida...")
        form_frame.wait_for_selector("select[name='cmbUnidMedida']", timeout=10000)
        form_frame.select_option("select[name='cmbUnidMedida']", "9")
        time.sleep(0.5)

        print("💲 Filling product value...")
        form_frame.wait_for_selector("input[name='edtVlProduto']", timeout=10000)
        form_frame.fill("input[name='edtVlProduto']", "100.00")
        time.sleep(0.5)

        print("🔢 Filling quantity...")
        form_frame.wait_for_selector("input[name='edtQtdProduto']", timeout=10000)
        form_frame.fill("input[name='edtQtdProduto']", "1")
        time.sleep(0.5)

        print("📊 Filling Aliquota...")
        form_frame.wait_for_selector("input[name='edtVlAliquota']", timeout=10000)
        form_frame.fill("input[name='edtVlAliquota']", "18")
        time.sleep(0.5)

        print("📄 Filling CST...")
        form_frame.wait_for_selector("select[name='cmbNrCST']", timeout=10000)
        # Try selecting by value first, then by label if that fails
        try:
            form_frame.select_option("select[name='cmbNrCST']", value="00")
        except Exception:
            try:
                form_frame.select_option(
                    "select[name='cmbNrCST']", label="00 - Tributada integralmente"
                )
            except Exception:
                try:
                    # Try selecting first available option
                    form_frame.select_option("select[name='cmbNrCST']", index=1)
                    print("  ⚠️  Selected first available CST option")
                except Exception:
                    print("  ⚠️  CST selection failed, continuing...")
        time.sleep(0.5)

        print("🏛 Filling Receita SEFIN...")
        form_frame.wait_for_selector("select[name='cmbSqReceitaSefin']", timeout=10000)
        form_frame.select_option("select[name='cmbSqReceitaSefin']", "335")
        time.sleep(0.5)

        print("📝 Filling Informações Adicionais...")
        form_frame.wait_for_selector(
            "textarea[name='txaInformacoesAdicionais']", timeout=10000
        )
        form_frame.fill(
            "textarea[name='txaInformacoesAdicionais']",
            "DOCUMENTO GERADO AUTOMATICAMENTE.",
        )
        time.sleep(0.5)

        print("🎯 DONE. Form is filled (not submitted). Keep window open.")
        time.sleep(9999)


if __name__ == "__main__":
    main()
