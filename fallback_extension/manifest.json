{
  "manifest_version": 3,
  "name": "NFA Fallback Autofill",
  "version": "1.0",
  "description": "Runs only when Playwright automation fails.",
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://www4.sefaz.pb.gov.br/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www4.sefaz.pb.gov.br/*"
      ],
      "js": [
        "fallback.js"
      ],
      "run_at": "document_end"
    }
  ]
}