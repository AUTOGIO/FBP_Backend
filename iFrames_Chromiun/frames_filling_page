// Obtém o texto de placa de um option da lista de veiculos
function obterPlaca (op) {

    var texto = op.text;
    var id = texto.indexOf("-");
    
    return texto.substring(id + 2, id + 9);
}

// Obtém o texto da uf de um option da lista de veiculos
function obterUF (op) {

    var texto = op.text;
    var id = texto.indexOf("-");
    var placaVeic = texto.substring(id + 2);
    var idUF = placaVeic.indexOf("/");

	if (idUF == -1) {
    	
		return "";
		
	}

    return placaVeic.substr(idUF + 1);

}

// Obtém o idVeiculo de um option da lista de veiculos
function obterIdVeiculo (op) {

    var texto = op.name;
    var id = texto.indexOf("¨");
   
    return texto.substring(0, id);
}

// Obtém o idVeiculo de um option da lista de veiculos
function obterSituacao (op) {

    var texto = op.name;
    var id = texto.indexOf("¨");
	
    return texto.substr(id + 1);
}

