function validaFormCalculoNotaFiscalNovo() {
	
	var formulario = document.frmIncluirNotaAvulsa;
	var cmb = formulario.cmbNrCST;
	var cst = cmb.options[cmb.selectedIndex].text.split(" - ")[0].trim();
	
	if (!algumMarcado(document.frmIncluirNotaAvulsa.chbProduto)) {

		mostraAlerta('Selecione o produto');
		return false;
		
	}
	
	if (ehVazio(cst)) {

		console.log("Chegou aqui viuuu!");
        mostraAlerta('O campo CST é obrigatório');
        formulario.cmbNrCST.focus();
        return false;
    }
	
  if (cst === '900') {
	  var pICMS = formulario.edtVlAliquotaICMS 
	      ? formulario.edtVlAliquotaICMS.value.trim() : '';	 

        if (ehVazio(pICMS)) {
            mostraAlerta("Para CST 900, o campo Alíquota ICMS (pICMS) é obrigatório");
            formulario.edtVlAliquotaICMS.focus();
            return false;
        }     
    }

    if (formulario.cmbSqReceitaSefin.value == "") {
        if (cst != '5' && cst != '6' && cst != '7') {
            mostraAlerta("O campo receita é obrigatório");
            return false;
        }
    }

    if (document.frmIncluirNotaAvulsa.edtCEST != null
        && ehVazio(document.frmIncluirNotaAvulsa.edtCEST.value)) {
        mostraAlerta('O campo CEST é obrigatório');
        document.frmIncluirNotaAvulsa.edtCEST.focus();
        return false;
    }

    if (ehVazio(formulario.edtGTIN.value)) {
        mostraAlerta("O campo GTIN é obrigatório");
        formulario.edtGTIN.focus();
        return false;
    }

    return true;
	
} // validaFormCalculoNotaFiscalNovo()

function itemRepetido() {

    var box = document.frmIncluirNotaAvulsa.chbProduto;
    var produtoSelecionado = document.frmIncluirNotaAvulsa.hidSqClassProdutocmpProduto.value;

    if (box != null) {

        if (box.length > 1) {

            for (i = 0; i < box.length; i++) {
                
                if (box[i].value == produtoSelecionado) {

                	return true;

                }
                
            }
            
        } else {
            
            if (box.value == produtoSelecionado) {
            
                return true;
                
            }
            
        }
        
    }

    return false;

} // itemRepetido()

function validaFormInclusao() {

	var motivo = obterTextoItemCombo(document.frmIncluirNotaAvulsa.cmbMotivo,
    		document.frmIncluirNotaAvulsa.cmbMotivo.value);

    if (ehVazio(document.frmIncluirNotaAvulsa.edtDtEmissao.value)) {

        mostraAlerta('Informe a data de emissão da nota');
        document.frmIncluirNotaAvulsa.edtDtEmissao.focus();
        return false;
        
    }
    
    if (validarDataMaior(document.frmIncluirNotaAvulsa.edtDtEmissao.value,
    		'04/12/2025')) {
    
    	mostraAlerta('A data de emissão da nota não pode ser superior a data atual');
        document.frmIncluirNotaAvulsa.edtDtEmissao.focus();
        return false;
        
    }

    if (!validaData(document.frmIncluirNotaAvulsa.edtDtEmissao.value)) {

        mostraAlerta(DATA_INVALIDA, "Data Emissão");
        document.frmIncluirNotaAvulsa.edtDtEmissao.focus();
        return false;
        
    }
    
    if (ehVazio(document.frmIncluirNotaAvulsa.hidSqUnidGeograficacmpMunicipioGiva.value)) {
    	
    	mostraAlerta('Informe o Município para Giva Fiscal');
    	cmpMunicipioGiva.iform.hidNoUnidGeograficacmpMunicipioGiva.focus();
        return false;
    	
    }
    
    if (ehVazio(document.frmIncluirNotaAvulsa.hidSqHumanoInstcmpEmitente.value)) {

        mostraAlerta('Informe o Emitente');
        cmpEmitente.iform.hidNrDocumentocmpEmitente.focus();
        return false;
        
    }
    
    if (motivo == "MUDANÇA") {
    	
		if (!validaCampoJS(document.frmIncluirNotaAvulsa.edtNoLograMud)) {
			
			document.frmIncluirNotaAvulsa.edtNoLograMud.focus();
	        return false;
			
		} //if
		
		if (!validaCampoJS(document.frmIncluirNotaAvulsa.edtNrLograMud)) {
			
	        document.frmIncluirNotaAvulsa.edtNrLograMud.focus();
	        return false;
			
		} //if
		
		if (!validaCampoJS(document.frmIncluirNotaAvulsa.edtCompLograMud)) {
			
			document.frmIncluirNotaAvulsa.edtCompLograMud.focus();
	        return false;
			
		} //if
		
		if (!validaCampoJS(document.frmIncluirNotaAvulsa.edtNoBairroMud)) {
			
			document.frmIncluirNotaAvulsa.edtNoBairroMud.focus();
	        return false;
			
		} //if
		
		if (!validaCampoJS(document.frmIncluirNotaAvulsa.edtCEPMud)) {
			
	        document.frmIncluirNotaAvulsa.edtCEPMud.focus();
	        return false;
			
		} //if
		
		if (ehVazio(document.frmIncluirNotaAvulsa.UGScmpMunicMud.value)) {

			mostraAlerta("O campo UF do Destinatário é obrigatório");
			document.frmIncluirNotaAvulsa.UGScmpMunicMud.focus();
			return false;
			
		} //if
		
		if (!validaCMP(cmpMunicMud, document.frmIncluirNotaAvulsa.hidSqUnidGeograficacmpMunicMud.value, 
				'Município do Destinatário', true)) {
			
			cmpMunicDest.iform.hidNoUnidGeograficacmpMunicMud.focus();
			return false;
			
		} //if
    	
    	
    }
    
    if (motivo == "IMPORTACAO" || motivo == "EXPORTACAO") {
    	
	    if (ehVazio(document.frmIncluirNotaAvulsa.edtIdEstrangeiro.value)) {
	    	
	        mostraAlerta('Informe Identificação Estrangeiro');
	        document.frmIncluirNotaAvulsa.edtIdEstrangeiro.focus();
	        return false;
	        
	    }
	    
	    if (!validaDocEstrangeiro(document.frmIncluirNotaAvulsa.edtIdEstrangeiro.value)) {
	    	
	    	mostraAlerta('Identificação Estrangeiro inválida');
	        document.frmIncluirNotaAvulsa.edtIdEstrangeiro.focus();
	        return false;
	    	
	    }

	    if (ehVazio(document.frmIncluirNotaAvulsa.edtNomeEstrangeiro.value)) {
	    	
	        mostraAlerta('Informe o Nome do Destinatário/Remetente');
	        document.frmIncluirNotaAvulsa.edtNomeEstrangeiro.focus();
	        return false;
	        
	    }
	    
	    if (ehVazio(document.frmIncluirNotaAvulsa.cmbPais.value)) {
	    	
	        mostraAlerta('Informe o Pais do Destinatário/Remetente');
	        document.frmIncluirNotaAvulsa.cmbPais.focus();
	        return false;
	        
	    }
	    
    } else {
    
	    if (ehVazio(document.frmIncluirNotaAvulsa.hidSqHumanoInstcmpDestinatario.value)) {
	
	        mostraAlerta('Informe o Destinatário/Remetente');
	        cmpDestinatario.iform.hidNrDocumentocmpDestinatario.focus();
	        return false;
	        
	    }
	    
    }

    if (ehVazio(document.frmIncluirNotaAvulsa.cmbTpOperacao.value)) {

        mostraAlerta('Informe o Tipo de Operação');
        document.frmIncluirNotaAvulsa.cmbTpOperacao.focus();
        return false;
        
    }
    
    if (ehVazio(document.frmIncluirNotaAvulsa.cmbNrCfop.value)) {

        mostraAlerta('Informe o número do CFOP');
        document.frmIncluirNotaAvulsa.cmbNrCfop.focus();
        return false;
        
    }

    if (ehVazio(document.frmIncluirNotaAvulsa.cmbNaturezaOperacao.value)) {

        mostraAlerta('Selecione a natureza da operação');
        document.frmIncluirNotaAvulsa.cmbNaturezaOperacao.focus();
        return false;
        
    }

    if (ehVazio(document.frmIncluirNotaAvulsa.cmbMotivo.value)) {
    
        mostraAlerta('Selecione o motivo da inclusão');
        document.frmIncluirNotaAvulsa.cmbMotivo.focus();
        return false;
        
    }
    
    if ((document.frmIncluirNotaAvulsa.cmbNrCfop.value == '5.601' 
    	|| document.frmIncluirNotaAvulsa.cmbNrCfop.value == '5.602')
		&& document.frmIncluirNotaAvulsa.cmbNaturezaOperacao.value != '68') {
    	
    	alert("Uma Nota Fiscal Avulsa cujo CFOP for 5.601(TRANSFERÊNCIA DE CRÉDITO DE ICMS ACUMULADO) "
