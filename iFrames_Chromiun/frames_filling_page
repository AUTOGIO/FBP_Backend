function atualizarValorPagar(obj) {
    var bcNota = parseFloat(formatoFloatJS(obj.value));

    var nameEdtBcNota = obj.name;
    var chave = nameEdtBcNota.substring(17);

    var campoAliquota = document.getElementsByName('edtVlAliquotaICMS' + chave)[0];
    var aliquota = 0;

    if (campoAliquota && campoAliquota.value) {
        aliquota = parseFloat(formatoFloatJS(campoAliquota.value));
    }

    var pagar = bcNota * (aliquota / 100);

    if (!isNaN(pagar)) {
        if (pagar < 0) pagar = 0;

        document.getElementsByName("edtVlImpostoICMS" + chave)[0].value = formataNumero(pagar + '', 2);
        document.getElementsByName("edtVlTotalRecolher" + chave)[0].value = formataNumero(pagar + '', 2);
        document.getElementsByName("hidVlTotalRecolher" + chave)[0].value = formataNumero(pagar + '', 2);
        document.getElementsByName("hidVlImpostoIcms" + chave)[0].value = formataNumero(pagar + '', 2);
    } else {
        document.getElementsByName("edtVlImpostoICMS" + chave)[0].value = '0,00';
        document.getElementsByName("edtVlTotalRecolher" + chave)[0].value = '0,00';
        document.getElementsByName("hidVlTotalRecolher" + chave)[0].value = '0,00';
        document.getElementsByName("hidVlImpostoIcms" + chave)[0].value = '0,00';
    }
}

