function validaFormItemNotaFiscal() {
	
    if (ehVazio(document.frmIncluirNotaAvulsa.cmbNaturezaOperacao.value)) {

        mostraAlerta('Selecione a natureza da operação');
        document.frmIncluirNotaAvulsa.cmbNaturezaOperacao.focus();
        return false;
        
    }
    
    if (ehVazio(document.frmIncluirNotaAvulsa.cmbMotivo.value)) {
        
        mostraAlerta('Selecione o motivo da inclusão');
        document.frmIncluirNotaAvulsa.cmbMotivo.focus();
        return false;
        
    }
	
	var motivo = obterTextoItemCombo(document.frmIncluirNotaAvulsa.cmbMotivo,
    		document.frmIncluirNotaAvulsa.cmbMotivo.value);
	
    if (motivo != "IMPORTACAO" && motivo != "EXPORTACAO" 
    		&& ehVazio(document.frmIncluirNotaAvulsa.hidSqHumanoInstcmpDestinatario.value)) {

        mostraAlerta('Informe o Destinatário/Remetente');
        cmpDestinatario.iform.hidNrDocumentocmpDestinatario.focus();
        return false;
        
    }

    if (ehVazio(document.frmIncluirNotaAvulsa.hidSqClassProdutocmpProduto.value)) {

        mostraAlerta(CAMPO_OBRIGATORIO, "Produto");
        cmpProduto.iform.hidNoClassProdutocmpProduto.focus();   
        return false;
        
    }
    
    if (!validaCampoJS(document.frmIncluirNotaAvulsa.txaDsDetalheProduto)) {
		
		return false;			
		
	}

    if (ehVazio(document.frmIncluirNotaAvulsa.cmbUnidMedida.value)) {

        mostraAlerta('Selecione a unidade de medida');
        document.frmIncluirNotaAvulsa.cmbUnidMedida.focus();
        return false;
        
    }

    if (ehVazio(document.frmIncluirNotaAvulsa.edtQtdProduto.value)) {

        mostraAlerta('Forneça a quantidade de produtos');
        document.frmIncluirNotaAvulsa.edtQtdProduto.focus();
        return false;
        
    }
    
    if (ehVazio(document.frmIncluirNotaAvulsa.edtVlAliquota.value)) {

        mostraAlerta('Forneça a alíquota');
        document.frmIncluirNotaAvulsa.edtVlAliquota.focus();
