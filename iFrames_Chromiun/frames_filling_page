    	document.frmIncluirNotaAvulsa.cmbNaturezaOperacao.focus();
    	
    	return false;
    	
    }
    
    if ((document.frmIncluirNotaAvulsa.cmbNrCfop.value == '5.601' 
    	|| document.frmIncluirNotaAvulsa.cmbNrCfop.value == '5.602') 
    	&& (motivo != "TRANSFERENCIA DE CREDITO")) {
    	
    	alert("Uma Nota Fiscal Avulsa cujo CFOP for 5.601(TRANSFERÊNCIA DE CRÉDITO DE ICMS ACUMULADO) "
    			+ "ou 5.602(TRANSFERÊNCIA DE SALDO CREDOR DE ICMS), deve ter como Motivo a TRANSFERÊNCIA DE CRÉDITO.");
    			
    	document.frmIncluirNotaAvulsa.cmbMotivo.focus();
    	
    	return false;
    	
    }
    
    if (document.frmIncluirNotaAvulsa.cmbNaturezaOperacao.value == '68'
    		&& (document.frmIncluirNotaAvulsa.cmbNrCfop.value != '5.601' 
    		&& document.frmIncluirNotaAvulsa.cmbNrCfop.value != '5.602')) {
    	
    	alert("Uma Nota Fiscal Avulsa cuja Natureza de Operação é TRANSFERÊNCIA DE CRÉDITO deve ter como CFOP o valor "
    			+ "5.601(TRANSFERÊNCIA DE CRÉDITO DE ICMS ACUMULADO) ou 5.602(TRANSFERÊNCIA DE SALDO CREDOR DE ICMS).");
    			
    	document.frmIncluirNotaAvulsa.cmbNrCfop.focus();
    	
    	return false;
    	
    }
    
    if (document.frmIncluirNotaAvulsa.cmbNaturezaOperacao.value == '68' 
	    && (motivo != "TRANSFERENCIA DE CREDITO")) {
    	
    	alert("Uma Nota Fiscal Avulsa cuja Natureza de Operação é TRANSFERÊNCIA DE CRÉDITO deve ter como "
    			+ "Motivo a TRANSFERÊNCIA DE CRÉDITO.");
    			
    	document.frmIncluirNotaAvulsa.cmbMotivo.focus();
    	
    	return false;
    	
    }
    
    if ((motivo == "TRANSFERENCIA DE CREDITO") 
    	&& (document.frmIncluirNotaAvulsa.cmbNrCfop.value != '5.601' 
    	&& document.frmIncluirNotaAvulsa.cmbNrCfop.value != '5.602')) {
    	
    	alert("Uma Nota Fiscal Avulsa cujo motivo é TRANSFERÊNCIA DE CRÉDITO deve possuir como CFOP "
    			+ "5.601(TRANSFERÊNCIA DE CRÉDITO DE ICMS ACUMULADO), ou 5.602(TRANSFERÊNCIA DE SALDO CREDOR DE ICMS).");
    			
    	document.frmIncluirNotaAvulsa.cmbNrCfop.focus();
    	
    	return false;
    	
    }
    
    if ((motivo == "TRANSFERENCIA DE CREDITO")
    		&& document.frmIncluirNotaAvulsa.cmbNaturezaOperacao.value != '68') {
    	
    	alert("Uma Nota Fiscal Avulsa cujo motivo é TRANSFERÊNCIA DE CRÉDITO deve possuir como natureza de operação "
    			+ "a TRANSFERÊNCIA DE CRÉDITO.");
    			
    	document.frmIncluirNotaAvulsa.cmbNaturezaOperacao.focus();
    	
    	return false;
    	
    }
    
    if ((motivo != "MUDANÇA" && motivo != "IMPORTACAO") 
