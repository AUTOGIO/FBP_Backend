function validaReutHumanoInst(nomeComponente, frm, campo) {
	
	var resultado = true;
	var tpDoc = eval(frm.name + ".cmbTpDoc" + nomeComponente);
	var hidCNPJ = eval(frm.name + ".hidCNPJ" + nomeComponente);
	var hidCPF = eval(frm.name + ".hidCPF" + nomeComponente);
	var hidNrATF = eval(frm.name + ".hidNrATF" + nomeComponente);
	var hidCnpjCpf = eval(frm.name + ".hidCnpjCpf" + nomeComponente);
	var cmp = eval(nomeComponente);
	
	if (ehVazio(tpDoc.value)) {
	
		mostraAlerta('Selecione o tipo de documento');
		tpDoc.focus();
		resultado = false;	
	}

	if (tpDoc.value	== '2') {	

		if (!validaCMP(cmp, hidCNPJ.value, campo, true)) {		
		
			resultado = false;		
		}//if
	} else if (tpDoc.value == '3') {

		if (!validaCMP(cmp, hidCPF.value, campo, true)) {			

			resultado = false;			
			
		}
	} else if (tpDoc.value == '16') {
			
		if (!validaCMP(cmp, hidNrATF.value, campo, true)) {			

			resultado = false;
			
		}//if
	} else {						
	
		if (!validaCMP(cmp, hidCnpjCpf.value, campo, true)) {			
			
			resultado = false;		
		}//if
	} //else
	
	return resultado;
	
} // validaReutHumanoInst()

