function validaForm() {
	
    if (document.frmIncluirNotaAvulsa.hidAcao.value == 'incluir') {

	 	return validaFormInclusao();

    } else if (document.frmIncluirNotaAvulsa.hidAcao.value == 'incluirItem') {

        return validaFormItemNotaFiscal();

    } else if (document.frmIncluirNotaAvulsa.hidAcao.value == 'alterarItem') {

        if (!algumMarcado(document.frmIncluirNotaAvulsa.chbProduto)) {

            mostraAlerta(SELECIONE_UM_ITEM, "Item");
            return false;

        }

        if (maisDeUmMarcado(document.frmIncluirNotaAvulsa.chbProduto)) {

            mostraAlerta("Selecione apenas um item para alterar");
            return false;

        }

    } else if (document.frmIncluirNotaAvulsa.hidAcao.value == 'removerItem') {

        if (!algumMarcado(document.frmIncluirNotaAvulsa.chbProduto)) {

            mostraAlerta(SELECIONE_UM_ITEM, "Item");
            return false;

        }

    } 
    return true;
    
} // validaForm()

function temCalculo(formulario) {

	var objChavePrimaria = formulario.chbChavePrimaria;
	
	var vlImpostoRecolher = null;
	
	if (objChavePrimaria != null) {
	
		if (objChavePrimaria[0] == null) {

			vlImpostoRecolher = formatoFloatJS(document.getElementById('edtVlTotalRecolher'
					+ objChavePrimaria.value).value);

			if (vlImpostoRecolher != null && vlImpostoRecolher > 0.0) {

				return true;
		
			}
	
		} else {

			var nrSequenciais = objChavePrimaria.length;
			
			for (i = 0; i < nrSequenciais; i++) {
			
				vlImpostoRecolher = formatoFloatJS(document.getElementById('edtVlTotalRecolher'
						+ objChavePrimaria[i].value).value);
					
				if (vlImpostoRecolher > 0.0) {
					
					return true;
						
				} // if
				
			} // for
	
		} // else
	
	} // if (objChavePrimaria != null) {
	
	return false;
	
} // temCalculo()

